# Keep the build context small and reproducible.
.git
.github
.gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# App data / secrets
data/
*.sqlite
*.sqlite-wal
*.sqlite-shm
.env
.env.*
!.env.example

# Frontend build artefacts (built inside the image)
frontend/node_modules/
frontend/dist/
src/energy_optimizer/web/static/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Docs not needed at runtime
*.md
!README.md

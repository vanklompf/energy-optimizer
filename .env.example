# energy-optimizer configuration. Copy to .env and edit.
# All variables are prefixed with EO_ and can also be set as real environment variables.

# --- General ---
EO_MODE=dry_run                     # dry_run only in MVP; controlled mode is future work
EO_TZ=Europe/Warsaw
EO_DB=/data/energy_optimizer.sqlite
EO_HTTP_HOST=0.0.0.0
EO_HTTP_PORT=8320
EO_LOG_LEVEL=INFO

# --- Home Assistant ---
EO_HA_URL=http://homeassistant.local:8123
EO_HA_TOKEN=                        # long-lived access token
EO_HA_VERIFY_SSL=true

# --- Pstryk (unified-metrics) ---
EO_PSTRYK_API_KEY=                  # sent as Authorization header, no Bearer prefix
EO_PSTRYK_BASE_URL=https://api.pstryk.pl
EO_PSTRYK_HISTORY_BOOTSTRAP_DAYS=21 # 14-30 days of historical prices to backfill on start

# --- MQTT (Home Assistant discovery) ---
EO_MQTT_HOST=
EO_MQTT_PORT=1883
EO_MQTT_USERNAME=
EO_MQTT_PASSWORD=
EO_MQTT_TLS=false
EO_MQTT_DISCOVERY_PREFIX=homeassistant
EO_MQTT_NODE_ID=energy_optimizer
EO_MQTT_CLIENT_ID=energy_optimizer
EO_MQTT_ENABLED=true

# --- Battery / site parameters (required; do not infer from ratings) ---
EO_BATTERY_CAPACITY_KWH=18.08
EO_BATTERY_MAX_CHARGE_KW=8.8
EO_BATTERY_MAX_DISCHARGE_KW=9.6
EO_BATTERY_SOC_MIN_PCT=20
EO_BATTERY_SOC_MAX_PCT=98
EO_BATTERY_ROUND_TRIP_EFFICIENCY=0.90       # eta_c = eta_d = sqrt(this)
EO_DEGRADATION_COST_PLN_PER_KWH=0.05        # per kWh of battery-side throughput, no implicit /2

# Site grid + inverter limits (required configuration)
EO_SITE_IMPORT_LIMIT_KW=14.0
EO_SITE_EXPORT_LIMIT_KW=14.0
EO_INVERTER_LIMIT_KW=12.0

# --- Pricing model ---
EO_IMPORT_PRICE_ADJUSTMENT_PLN_KWH=0.0      # only for invoice components proven missing

# --- Optimiser feature flags / safety margins ---
EO_ALLOW_BATTERY_EXPORT=true
EO_ALLOW_GRID_CHARGING=true
EO_MINIMUM_EXPORT_SPREAD_PLN_KWH=0.30
EO_GRID_CHARGE_MARGIN_PLN_KWH=0.30
EO_TERMINAL_SOC_SALVAGE_PLN_KWH=0.0
EO_OPTIMISE_HORIZON_HOURS=48
EO_STEP_MINUTES=15

# --- PV forecast (Forecast.Solar); one or more planes may be configured ---
EO_PV_LAT=51.9194
EO_PV_LON=19.1451
EO_PV_PLANES=[{"peak_kwp":7.0,"tilt":35,"azimuth":0,"inverter_limit_kw":7.0}]
EO_PV_FORECAST_PROVIDER=forecast_solar       # forecast_solar | solcast | none
EO_SOLCAST_API_KEY=

# --- Optional read-only InfluxDB history bootstrap ---
EO_INFLUXDB_BOOTSTRAP_ENABLED=false
EO_INFLUXDB_URL=
EO_INFLUXDB_TOKEN=
EO_INFLUXDB_ORG=
EO_INFLUXDB_BUCKET=ha_raw
